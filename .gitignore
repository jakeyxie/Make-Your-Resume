# Node.js / npm
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# Vue / Vite — 前端构建产物
# ============================================
vue/dist/
vue/.vite/

# ============================================
# Java / Maven — 后端构建产物
# ============================================
springboot/target/
springboot/.idea/
springboot/*.iml

# Maven wrapper (如果不需要提交)
# springboot/.mvn/
# springboot/mvnw
# springboot/mvnw.cmd

# ============================================
# META-INF — Maven/IDE 自动生成
# ============================================
META-INF/

# ============================================
# IDE 输出目录
# ============================================
out/

# ============================================
# 运行时上传文件目录
# ============================================
files/

