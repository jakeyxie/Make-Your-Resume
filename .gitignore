.idea/
*.iml
*.iws
*.ipr

# ============================================
# IDE — VS Code (备选编辑器)
# ============================================
.vscode/

# ============================================
# OS generated files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

