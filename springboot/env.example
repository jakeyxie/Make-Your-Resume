# ============================================
# 环境变量配置模板 (Spring Boot)
# 复制为环境变量或创建 application-local.yml 覆盖
# ============================================

# 数据库密码
DB_PASSWORD=123456

# SMTP授权码（QQ邮箱）
SMTP_PASSWORD=your-smtp-auth-code

# JWT签名密钥（生产环境请更换为长随机字符串）
JWT_SECRET=my-resume-jwt-secret-key-2025

# CORS允许的来源（多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# 前端地址（用于邮件重置链接）
FRONTEND_URL=http://localhost:5173
