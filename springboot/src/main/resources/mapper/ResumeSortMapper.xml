<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.ResumeSortMapper">
    <select id="selectAllSorts" resultType="com.example.entity.ResumeSort">
        select * from `resumesort` order by resumeSortId
    </select>

    <select id="selectAll" resultType="com.example.entity.ResumeSort">
        select * from `resumesort`
        <where>
            <if test="sort != null and sort != ''">and sort like concat('%', #{sort}, '%')</if>  <!-- 相当于 name like '%1%' -->
        </where>
        order by resumeSortId desc
    </select>

    <insert id="insert">
        insert into `resumesort` (sort)
        values(#{sort})
    </insert>

    <update id="updateById">
        update `resumesort` set sort = #{sort}
        where resumeSortId = #{resumeSortId}
    </update>
</mapper>